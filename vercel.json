{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/cron/refresh-open-house-data",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/generate-agent-outreach",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/render-agent-mockups",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/send-agent-outreach",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/replay-android-inbox",
      "schedule": "*/15 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "getrel8tion.com" }],
      "destination": "/get-open-house-kit",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.getrel8tion.com" }],
      "destination": "/get-open-house-kit",
      "permanent": false
    }
  ],
